<ui:FluentWindow x:Class="BuptGpaCalculator.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="BUPT GPA Calculator"
                 Width="1024"
                 Height="640"
                 MinWidth="1024"
                 MinHeight="640"
                 FontFamily="Microsoft YaHei UI, Segoe UI Variable Text, Segoe UI"
                 TextOptions.TextFormattingMode="Ideal"
                 TextOptions.TextRenderingMode="Auto"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowStartupLocation="CenterScreen"
                 Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="BUPT GPA Calculator" Icon="{ui:ImageIcon 'pack://application:,,,/Assets/Favicon.png'}" />

        <Border Grid.Row="1" Padding="18,10,18,12" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:Button x:Name="OverviewNavButton" Content="成绩概览" Appearance="Primary" Click="OverviewNavigationButton_Click" Margin="0,0,6,0" />
                    <ui:Button x:Name="CoursesNavButton" Content="课程记录" Appearance="Secondary" Click="CoursesNavigationButton_Click" Margin="0,0,6,0" />
                    <ui:Button x:Name="RulesNavButton" Content="计算规则" Appearance="Secondary" Click="RulesNavigationButton_Click" Margin="0,0,6,0" />
                    <ui:Button x:Name="HelpNavButton" Content="使用说明" Appearance="Secondary" Click="HelpNavigationButton_Click" />
                </StackPanel>

                <Border Grid.Column="1" Width="1" Height="24" Background="{DynamicResource TextFillColorTertiaryBrush}" Opacity="0.58" Margin="10,0" VerticalAlignment="Center" />

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ComboBox x:Name="StudentComboBox" Width="210" DisplayMemberPath="DisplayName" SelectionChanged="StudentComboBox_SelectionChanged" />
                    <ui:Button Content="新增学生" Appearance="Secondary" Click="AddStudent_Click" Margin="8,0,0,0" />
                    <ui:Button Content="管理" Appearance="Secondary" Click="ManageStudent_Click" Margin="6,0,0,0" />
                </StackPanel>

                <Border Grid.Column="3" Width="1" Height="24" Background="{DynamicResource TextFillColorTertiaryBrush}" Opacity="0.58" Margin="10,0" VerticalAlignment="Center" />

                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:Button Content="新建档案" Appearance="Secondary" Click="NewArchive_Click" Margin="0,0,6,0" />
                    <ui:Button Content="打开" Appearance="Secondary" Click="OpenArchive_Click" Margin="0,0,6,0" />
                    <ui:Button Content="另存" Appearance="Secondary" Click="SaveAs_Click" Margin="0,0,6,0" />
                    <ui:Button Content="保存" Appearance="Primary" Click="Save_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="22,18,22,16">
            <Grid x:Name="WelcomePanel">
                <Border Style="{StaticResource SoftCard}" Width="430" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="30">
                    <StackPanel>
                        <TextBlock x:Name="WelcomeTitleTextBlock" Text="从一个成绩档案开始" FontSize="25" FontWeight="SemiBold" HorizontalAlignment="Center" />
                        <TextBlock x:Name="WelcomePrimaryTextBlock" Text="档案是独立的单个 .db 文件" TextAlignment="Center" Opacity="0.68" Margin="0,10,0,0" />
                        <TextBlock x:Name="WelcomeSecondaryTextBlock" Text="程序不会在其他位置写入成绩数据" TextAlignment="Center" Opacity="0.58" Margin="0,3,0,24" />
                        <ui:Button x:Name="WelcomePrimaryButton" Content="新建成绩档案" Appearance="Primary" Click="WelcomePrimaryButton_Click" HorizontalAlignment="Stretch" Margin="0,0,0,8" />
                        <ui:Button x:Name="WelcomeSecondaryButton" Content="打开已有档案" Appearance="Secondary" Click="WelcomeSecondaryButton_Click" HorizontalAlignment="Stretch" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid x:Name="OverviewPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="成绩概览" FontSize="24" FontWeight="SemiBold" />
                        <TextBlock x:Name="OverviewSubtitleTextBlock" Text="打开档案后查看统计结果" Opacity="0.66" Margin="0,3,0,0" />
                    </StackPanel>
                    <ComboBox x:Name="OverviewTermComboBox" Grid.Column="1" Width="170" DisplayMemberPath="DisplayName" VerticalAlignment="Center" SelectionChanged="OverviewScope_Changed" />
                </Grid>

                <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,14">
                    <Border Style="{StaticResource SoftCard}" Margin="0,0,8,0" Padding="16,13" ToolTip="按计入课程的学分加权绩点计算"><StackPanel><TextBlock Text="GPA" Opacity="0.68" /><TextBlock x:Name="GpaTextBlock" Text="—" Style="{StaticResource MetricValue}" /></StackPanel></Border>
                    <Border Style="{StaticResource SoftCard}" Margin="0,0,8,0" Padding="16,13" ToolTip="按计入课程的学分加权成绩计算"><StackPanel><TextBlock Text="GA" Opacity="0.68" /><TextBlock x:Name="GaTextBlock" Text="—" Style="{StaticResource MetricValue}" /></StackPanel></Border>
                    <Border Style="{StaticResource SoftCard}" Margin="0,0,8,0" Padding="16,13" ToolTip="显示当前范围内所有已录入课程的学分总和"><StackPanel><TextBlock Text="已修总学分" Opacity="0.68" /><TextBlock x:Name="TotalCreditTextBlock" Text="—" Style="{StaticResource MetricValue}" /></StackPanel></Border>
                    <Border x:Name="CurrentTermGaCard" Style="{StaticResource SoftCard}" Padding="16,13" ToolTip="固定显示全部课程中的最新学期 GA，不随左侧范围筛选变化"><StackPanel><TextBlock Text="最新学期 GA" Opacity="0.68" /><TextBlock x:Name="CurrentTermGaTextBlock" Text="—" Style="{StaticResource MetricValue}" /></StackPanel></Border>
                </UniformGrid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource SoftCard}" Grid.Column="0" Padding="16" Margin="0,0,8,0">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="TrendTitleTextBlock" Text="学期 GA 趋势" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <ui:Button x:Name="ToggleTrendMetricButton" Grid.Column="1" Appearance="Secondary" Width="22" Height="22" Padding="0" ToolTip="切换为 GPA 趋势" Click="ToggleTrendMetric_Click">
                                    <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE895;" FontSize="11" />
                                </ui:Button>
                            </Grid>
                            <Canvas x:Name="TrendCanvas" MinHeight="210" SizeChanged="ChartCanvas_SizeChanged" />
                        </DockPanel>
                    </Border>
                    <Border Style="{StaticResource SoftCard}" Grid.Column="1" Padding="16">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="成绩分布" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <Canvas x:Name="DistributionCanvas" MinHeight="210" SizeChanged="ChartCanvas_SizeChanged" />
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>

            <Grid x:Name="CoursesPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="课程记录" FontSize="24" FontWeight="SemiBold" />
                        <TextBlock Text="教务导入会保留教务顺序；来源显示为导入、修改或手动。" Opacity="0.66" Margin="0,3,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:Button Content="导入教务成绩" Appearance="Primary" Click="ImportCourses_Click" Margin="0,0,6,0" ToolTip="粘贴并识别教务系统课程成绩表" />
                        <ui:Button Content="新增课程" Appearance="Secondary" Click="AddCourse_Click" Margin="0,0,6,0" />
                        <ui:Button Content="编辑" Appearance="Secondary" Click="EditCourse_Click" Margin="0,0,6,0" />
                        <ui:Button Content="删除" Appearance="Secondary" Click="DeleteCourse_Click" ToolTip="删除选中的课程记录" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="120" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBox x:Name="SearchTextBox" PlaceholderText="搜索课程、编号或学期" TextChanged="Filter_Changed" Margin="0,0,8,0" />
                    <ComboBox x:Name="TermFilterComboBox" Grid.Column="1" SelectionChanged="Filter_Changed" Margin="0,0,8,0" />
                    <ComboBox x:Name="IncludedFilterComboBox" Grid.Column="2" SelectionChanged="Filter_Changed">
                        <ComboBoxItem Content="全部课程" Tag="all" IsSelected="True" />
                        <ComboBoxItem Content="仅计入" Tag="included" />
                        <ComboBoxItem Content="仅不计入" Tag="excluded" />
                    </ComboBox>
                </Grid>

                <Grid Grid.Row="2">
                    <DataGrid x:Name="CourseDataGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              SelectionMode="Extended"
                              HorizontalScrollBarVisibility="Disabled"
                              PreviewMouseWheel="DataGrid_PreviewMouseWheel"
                              MouseDoubleClick="CourseDataGrid_MouseDoubleClick"
                              Sorting="CourseDataGrid_Sorting"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="学期" Binding="{Binding Term}" SortMemberPath="Term" Width="120" />
                            <DataGridTextColumn Header="课程编号" Binding="{Binding CourseCode}" SortMemberPath="CourseCode" Width="125" />
                            <DataGridTextColumn Header="课程名称" Binding="{Binding CourseName}" SortMemberPath="CourseName" Width="*" MinWidth="200" />
                            <DataGridTextColumn Header="成绩" Binding="{Binding ScoreDisplayText}" SortMemberPath="ScoreValue" Width="96" />
                            <DataGridTextColumn Header="学分" Binding="{Binding CreditText}" SortMemberPath="CreditText" Width="76" />
                            <DataGridTemplateColumn Header="计入" SortMemberPath="IsIncluded" Width="48">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="{Binding IncludedToolTip}">
                                            <Ellipse Width="9" Height="9">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="#8A8F98" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsIncluded}" Value="True">
                                                                <Setter Property="Fill" Value="#2BA84A" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="来源" SortMemberPath="SourceLabel" Width="54">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SourceLabel}" ToolTip="{Binding SourceToolTip}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel x:Name="EmptyCoursesHintPanel" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False" Visibility="Collapsed">
                        <TextBlock Text="暂无课程记录" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Opacity="0.82" />
                        <TextBlock Text="点击右上角“导入教务成绩”或“新增课程”开始" TextAlignment="Center" Opacity="0.58" Margin="0,6,0,0" />
                    </StackPanel>
                </Grid>
            </Grid>

            <Grid x:Name="RulesPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="计算规则" FontSize="24" FontWeight="SemiBold" />
                    <TextBlock Text="百分制、五级制和两级制成绩按北邮官方表换算；0 学分或标记为不计入的课程不会影响 GPA 与 GA。" TextWrapping="Wrap" Opacity="0.66" Margin="0,3,0,0" />
                </StackPanel>
                <DataGrid x:Name="RuleDataGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column" Margin="0,0,0,14" Focusable="False" HorizontalScrollBarVisibility="Disabled" PreviewMouseWheel="DataGrid_PreviewMouseWheel" PreviewMouseLeftButtonDown="ReadOnlyDataGrid_PreviewMouseLeftButtonDown">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="百分制成绩" Binding="{Binding PercentageDisplayText}" Width="*" />
                        <DataGridTextColumn Header="五级制成绩" Binding="{Binding FiveLevelText}" Width="*" />
                        <DataGridTextColumn Header="两级制成绩" Binding="{Binding TwoLevelText}" Width="*" />
                        <DataGridTextColumn Header="绩点成绩" Binding="{Binding GradePointDisplayText}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
                <TextBlock Grid.Row="2" Text="当前计算明细" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8" />
                <Grid Grid.Row="3">
                    <DataGrid x:Name="CalculationDataGrid" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column" Focusable="False" HorizontalScrollBarVisibility="Disabled" PreviewMouseWheel="DataGrid_PreviewMouseWheel" PreviewMouseLeftButtonDown="ReadOnlyDataGrid_PreviewMouseLeftButtonDown">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="课程" Binding="{Binding CourseName}" Width="*" />
                            <DataGridTextColumn Header="成绩" Binding="{Binding Score}" Width="104" />
                            <DataGridTextColumn Header="学分" Binding="{Binding Credit}" Width="72" />
                            <DataGridTextColumn Header="绩点" Binding="{Binding GradePoint}" Width="72" />
                            <DataGridTextColumn Header="GA 贡献" Binding="{Binding GradeAverageWeight}" Width="100" />
                            <DataGridTextColumn Header="GPA 贡献" Binding="{Binding GpaWeight}" Width="100" />
                            <DataGridTemplateColumn Header="计入" Width="54">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="{Binding IncludedText}">
                                            <Ellipse Width="9" Height="9">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="#8A8F98" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsIncluded}" Value="True">
                                                                <Setter Property="Fill" Value="#2BA84A" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel x:Name="EmptyCalculationHintPanel" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False" Visibility="Collapsed">
                        <TextBlock Text="暂无计算明细" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Opacity="0.82" />
                        <TextBlock Text="添加计入统计的课程后将在这里显示逐课贡献" TextAlignment="Center" Opacity="0.58" Margin="0,6,0,0" />
                    </StackPanel>
                </Grid>
            </Grid>

            <Grid x:Name="HelpPanel" Visibility="Collapsed">
                <Grid MaxWidth="660" HorizontalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="使用说明" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <TextBlock Text="一个档案可以保存多名学生；档案位置完全由你选择。" Opacity="0.68" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,12,0,12">
                        <Border Style="{StaticResource SoftCard}" Padding="16" Margin="0,0,0,9"><StackPanel><TextBlock Text="新建或打开档案" FontWeight="SemiBold" /><TextBlock Text="首次使用时选择一个位置创建 .db 档案；以后可随时打开或另存为该文件。" TextWrapping="Wrap" Opacity="0.72" Margin="0,5,0,0" /></StackPanel></Border>
                        <Border Style="{StaticResource SoftCard}" Padding="16" Margin="0,0,0,9"><StackPanel><TextBlock Text="复制并导入教务成绩" FontWeight="SemiBold" /><TextBlock Text="在教务系统成绩表内点一下，按 Ctrl+A、Ctrl+C；回到本软件点击“识别成绩表”。软件不会自动访问教务系统。" TextWrapping="Wrap" Opacity="0.72" Margin="0,5,0,0" /></StackPanel></Border>
                        <Border Style="{StaticResource SoftCard}" Padding="16"><StackPanel><TextBlock Text="核对与保存" FontWeight="SemiBold" /><TextBlock Text="课程来源显示为导入、修改或手动；计入列使用绿色或灰色圆点表示是否参与计算。点击列标题可在升序、降序和默认顺序之间切换。" TextWrapping="Wrap" Opacity="0.72" Margin="0,5,0,0" /></StackPanel></Border>
                    </StackPanel>

                    <Grid Grid.Row="2" Margin="4,0,0,0" VerticalAlignment="Bottom">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.ColumnSpan="2">
                            <TextBlock x:Name="AppVersionTextBlock" Text="BUPT GPA Calculator" FontWeight="SemiBold" Opacity="0.72" />
                            <TextBlock Text="lte_z · 小Z工作室#2026" Opacity="0.56" Margin="0,4,0,0" />
                        </StackPanel>
                        <TextBlock Grid.Row="1" Text="如果这个小工具帮到了你，欢迎点个 Star，也欢迎提交建议或参与贡献！" TextWrapping="Wrap" Opacity="0.56" Margin="0,10,0,0" VerticalAlignment="Bottom" />
                        <StackPanel Grid.RowSpan="2" Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Bottom">
                            <ui:Button Content="用户指南" Appearance="Secondary" Click="OpenUserGuide_Click" HorizontalAlignment="Stretch" Margin="0,0,0,6" />
                            <ui:Button Content="GitHub 仓库" Appearance="Secondary" Click="OpenRepository_Click" HorizontalAlignment="Stretch" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <Border Grid.Row="3" Padding="18,7" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
            <TextBlock x:Name="StatusTextBlock" Text="新建或打开一个成绩档案以开始。" Opacity="0.70" FontSize="12" />
        </Border>

        <ui:ContentDialogHost x:Name="RootDialogHost" Grid.RowSpan="4" />
        <ui:SnackbarPresenter x:Name="RootSnackbarPresenter" Grid.RowSpan="4" Margin="0,0,18,18" HorizontalAlignment="Right" VerticalAlignment="Bottom" />
    </Grid>
</ui:FluentWindow>
